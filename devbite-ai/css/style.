/* ================================================= */
/* ==================== RESET ====================== */
/* ================================================= */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html,
body{

    width:100%;
    height:100%;

    overflow:hidden;

    font-family:'Inter',sans-serif;

    background:
    radial-gradient(
        circle at top left,
        #172554 0%,
        #020617 45%,
        #000000 100%
    );

    color:white;
}

/* ================================================= */
/* ================= MAIN LAYOUT =================== */
/* ================================================= */

.main-layout{

    width:100%;
    height:100vh;

    display:flex;

    gap:20px;

    padding:20px;
}

/* ================================================= */
/* ==================== SIDEBAR ==================== */
/* ================================================= */

.sidebar{

    width:250px;

    height:100%;

    border-radius:30px;

    background:
    rgba(255,255,255,0.04);

    border:
    1px solid rgba(255,255,255,0.06);

    backdrop-filter:blur(30px);

    padding:18px;

    display:flex;

    flex-direction:column;

    animation:fadeLeft .45s ease;

    box-shadow:
    inset 0 1px rgba(255,255,255,0.08),
    0 10px 40px rgba(0,0,0,.35);
}
#searchChatWrap { display: none; }
#searchChatWrap.show-search { display: block !important; }

/* ================================================= */
/* ================= SIDEBAR TOP =================== */
/* ================================================= */

.sidebar-top{

    display:flex;

    flex-direction:column;

    gap:18px;

    margin-bottom:28px;
}

/* ===== LOGO ===== */

.logo-mini{

    width:48px;
    height:48px;

    border-radius:16px;

    display:flex;

    align-items:center;
    justify-content:center;

    font-size:22px;

    background:
    linear-gradient(
        135deg,
        #3b82f6,
        #06b6d4
    );

    box-shadow:
    0 10px 30px rgba(59,130,246,.35);

    animation:float 4s ease infinite;
}

/* ===== BUTTON ===== */

.new-chat-btn{

    height:48px;

    border:none;

    border-radius:18px;

    background:
    rgba(255,255,255,0.05);

    border:
    1px solid rgba(255,255,255,0.08);

    color:white;

    font-size:14px;

    cursor:pointer;

    transition:.25s ease;
}

.new-chat-btn:hover{

    transform:
    translateY(-2px);

    background:
    rgba(255,255,255,0.08);

    box-shadow:
    0 10px 30px rgba(0,0,0,.2);
}

/* ================================================= */
/* ================= SIDEBAR TITLE ================= */
/* ================================================= */

.sidebar-title{

    font-size:11px;

    letter-spacing:1px;

    color:#64748b;

    margin-bottom:12px;

    padding-left:6px;
}

/* ================================================= */
/* ==================== MENU ======================= */
/* ================================================= */

.side-item{

    display:flex;

    align-items:center;

    gap:12px;

    height:48px;

    padding:0 16px;

    border-radius:16px;

    cursor:pointer;

    color:#cbd5e1;

    transition:.25s ease;

    margin-bottom:8px;

    background:
    transparent;
}

.side-item:hover{

    background:
    rgba(255,255,255,0.06);

    transform:
    translateX(4px);
}

/* ===== ICON ===== */

.side-item i{

    font-size:18px;

    opacity:.9;
}

/* ================================================= */
/* ================= RECENT CHAT =================== */
/* ================================================= */

.recent-chat{

    padding:13px 15px;

    border-radius:16px;

    color:#94a3b8;

    font-size:14px;

    cursor:pointer;

    transition:.25s ease;

    margin-bottom:8px;
}

.recent-chat:hover{

    background:
    rgba(255,255,255,0.06);

    color:white;
}

/* ================================================= */
/* =================== PROFILE ===================== */
/* ================================================= */

.sidebar-bottom{

    margin-top:auto;
}

.profile{

    display:flex;

    align-items:center;

    gap:12px;

    padding:14px;

    border-radius:20px;

    background:
    rgba(255,255,255,0.05);

    border:
    1px solid rgba(255,255,255,0.08);
}

.avatar{

    width:42px;
    height:42px;

    border-radius:14px;

    display:flex;

    align-items:center;
    justify-content:center;

    background:
    linear-gradient(
        135deg,
        #2563eb,
        #06b6d4
    );

    font-weight:700;
}

.profile h4{

    font-size:14px;
}

.profile span{

    font-size:12px;

    color:#94a3b8;
}

/* ================================================= */
/* ==================== MAIN ======================= */
/* ================================================= */

.chat-main{

    flex:1;

    display:flex;

    flex-direction:column;

    gap:18px;

    animation:fadeUp .45s ease;
}

/* ================================================= */
/* =================== TOPBAR ====================== */
/* ================================================= */

.topbar{

    display:flex;

    justify-content:space-between;

    align-items:center;

    padding:4px 6px;
}

.topbar h1{

    font-size:34px;

    font-weight:700;

    margin-bottom:4px;
}

.topbar p{

    color:#94a3b8;

    font-size:14px;
}

/* ===== STATUS ===== */

.status{

    padding:10px 16px;

    border-radius:999px;

    background:
    rgba(34,197,94,.12);

    border:
    1px solid rgba(74,222,128,.2);

    color:#4ade80;

    font-size:14px;

    box-shadow:
    0 0 25px rgba(74,222,128,.08);
}

/* ================================================= */
/* ================= CHAT CONTAINER ================ */
/* ================================================= */

.chat-container{

    flex:1;

    display:flex;

    flex-direction:column;

    overflow:hidden;

    border-radius:32px;

    background:
    rgba(255,255,255,0.04);

    border:
    1px solid rgba(255,255,255,0.06);

    backdrop-filter:blur(30px);

    box-shadow:
    inset 0 1px rgba(255,255,255,0.05),
    0 20px 50px rgba(0,0,0,.35);
}

/* ================================================= */
/* ==================== CHATBOX ==================== */
/* ================================================= */

.chat-box{

    flex:1;

    overflow-y:auto;

    padding:28px;

    display:flex;

    flex-direction:column;

    gap:18px;

    scroll-behavior:smooth;
}

/* ===== SCROLL ===== */

.chat-box::-webkit-scrollbar{

    width:5px;
}

.chat-box::-webkit-scrollbar-thumb{

    background:
    rgba(255,255,255,.12);

    border-radius:20px;
}

/* ================================================= */
/* ==================== MESSAGE ==================== */
/* ================================================= */

.message{

    width:fit-content;

    max-width:76%;

    padding:16px 20px;

    border-radius:24px;

    line-height:1.8;

    font-size:15px;

    animation:messageIn .25s ease;
}

/* ===== USER ===== */

.user-message{

    margin-left:auto;

    background:
    linear-gradient(
        135deg,
        #2563eb,
        #06b6d4
    );

    box-shadow:
    0 10px 30px rgba(37,99,235,.25);

    color:white;
}

/* ===== BOT ===== */

.bot-message{

    margin-right:auto;

    background:
    rgba(255,255,255,0.05);

    border:
    1px solid rgba(255,255,255,0.08);

    color:#f8fafc;
}

/* ================================================= */
/* ================== ACTION BAR =================== */
/* ================================================= */

.action-bar{

    display:flex;

    gap:10px;

    padding:0 24px 18px;
}

.action-bar button{

    width:42px;
    height:42px;

    border:none;

    border-radius:14px;

    background:
    rgba(255,255,255,0.05);

    border:
    1px solid rgba(255,255,255,0.08);

    color:white;

    cursor:pointer;

    transition:.25s ease;
}

.action-bar button:hover{

    transform:
    translateY(-2px);

    background:
    rgba(255,255,255,0.08);

    box-shadow:
    0 10px 25px rgba(0,0,0,.18);
}

.action-bar button i{

    font-size:18px;
}

/* ================================================= */
/* ==================== INPUT ====================== */
/* ================================================= */

.chat-input{

    padding:0 24px 24px;

    display:flex;

    align-items:center;

    gap:14px;
}

.chat-input input{

    flex:1;

    height:60px;

    border:none;

    outline:none;

    border-radius:20px;

    padding:0 22px;

    background:
    rgba(255,255,255,0.05);

    border:
    1px solid rgba(255,255,255,0.08);

    color:white;

    font-size:15px;

    transition:.25s ease;
}

.chat-input input::placeholder{

    color:#94a3b8;
}

.chat-input input:focus{

    border:
    1px solid #38bdf8;

    box-shadow:
    0 0 25px rgba(56,189,248,.15);
}

/* ===== SEND ===== */

.chat-input button{

    width:60px;
    height:60px;

    border:none;

    border-radius:20px;

    cursor:pointer;

    color:white;

    font-size:20px;

    background:
    linear-gradient(
        135deg,
        #2563eb,
        #06b6d4
    );

    transition:.25s ease;
}

.chat-input button:hover{

    transform:
    translateY(-2px)
    scale(1.03);

    box-shadow:
    0 10px 30px rgba(37,99,235,.35);
}

/* ================================================= */
/* ==================== TYPING ===================== */
/* ================================================= */

.typing{

    width:fit-content;

    display:flex;

    gap:6px;

    padding:14px 18px;

    border-radius:18px;

    background:
    rgba(255,255,255,0.05);
}

.typing span{

    width:8px;
    height:8px;

    border-radius:50%;

    background:#94a3b8;

    animation:blink 1.2s infinite;
}

.typing span:nth-child(2){

    animation-delay:.2s;
}

.typing span:nth-child(3){

    animation-delay:.4s;
}

/* ================================================= */
/* ================== ANIMATIONS =================== */
/* ================================================= */

@keyframes blink{

    0%,80%,100%{

        opacity:.3;

        transform:scale(.8);
    }

    40%{

        opacity:1;

        transform:scale(1);
    }
}

@keyframes messageIn{

    from{

        opacity:0;

        transform:
        translateY(10px)
        scale(.98);
    }

    to{

        opacity:1;

        transform:
        translateY(0)
        scale(1);
    }
}

@keyframes fadeLeft{

    from{

        opacity:0;

        transform:translateX(-20px);
    }

    to{

        opacity:1;

        transform:translateX(0);
    }
}

@keyframes fadeUp{

    from{

        opacity:0;

        transform:translateY(20px);
    }

    to{

        opacity:1;

        transform:translateY(0);
    }
}

@keyframes float{

    0%{

        transform:translateY(0px);
    }

    50%{

        transform:translateY(-4px);
    }

    100%{

        transform:translateY(0px);
    }
}

/* ================================================= */
/* ==================== MOBILE ===================== */
/* ================================================= */

@media(max-width:900px){

    .sidebar{

        display:none;
    }

    .main-layout{

        padding:10px;
    }

    .topbar h1{

        font-size:24px;
    }
}
/* ===== ACTION BAR ACTIVE STATE ===== */
.action-bar button.recording {
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
    border-color: #ef4444;
    animation: pulse-red 1s infinite;
}

.action-bar button.active-tool {
    background: rgba(56, 189, 248, 0.15);
    color: #38bdf8;
    border-color: #38bdf8;
}

@keyframes pulse-red {
    0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.4); }
    50%       { box-shadow: 0 0 0 6px rgba(239,68,68,0); }
}

/* ===== FILE PREVIEW BUBBLE ===== */
.file-preview-bubble {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 10px 14px;
    min-width: 220px;
}

.fpb-icon { font-size: 28px; }

.fpb-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.fpb-name {
    font-size: 13px;
    font-weight: 600;
    color: white;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.fpb-size { font-size: 11px; color: #64748b; }

/* ===== AUDIO PREVIEW BUBBLE ===== */
.audio-preview-bubble {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 10px 14px;
}

/* ===== IMAGE PREVIEW BUBBLE ===== */
.img-preview-bubble {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.img-preview-bubble img {
    max-width: 240px;
    max-height: 200px;
    border-radius: 12px;
    object-fit: cover;
    cursor: zoom-in;
    border: 1px solid rgba(255,255,255,0.08);
    transition: transform .2s;
}

.img-preview-bubble img:hover { transform: scale(1.02); }

.img-name {
    font-size: 11px;
    color: #64748b;
}

/* ===== TOAST ===== */
.devbyte-toast {
    position: fixed;
    bottom: 90px;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: #1e293b;
    border: 1px solid rgba(255,255,255,0.1);
    color: #e2e8f0;
    font-size: 13px;
    padding: 10px 18px;
    border-radius: 20px;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s, transform .25s;
    white-space: nowrap;
}

.devbyte-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
}

.devbyte-toast.toast-error { border-color: #ef4444; color: #fca5a5; }
.devbyte-toast.toast-recording { border-color: #ef4444; color: #fca5a5; }
.devbyte-toast.toast-info { border-color: #38bdf8; color: #7dd3fc; }

/* ===== SETTINGS MODAL ===== */
.settings-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    font-size: 14px;
    color: #cbd5e1;
}

.toggle-switch {
    position: relative;
    width: 42px;
    height: 24px;
    cursor: pointer;
}

.toggle-switch input { display: none; }

.toggle-slider {
    position: absolute;
    inset: 0;
    background: #334155;
    border-radius: 24px;
    transition: .3s;
}

.toggle-slider::before {
    content: '';
    position: absolute;
    width: 18px; height: 18px;
    left: 3px; top: 3px;
    background: white;
    border-radius: 50%;
    transition: .3s;
}

.toggle-switch input:checked + .toggle-slider { background: #2563eb; }
.toggle-switch input:checked + .toggle-slider::before { transform: translateX(18px); }

/* ===== MODAL OVERLAY (nếu chưa có) ===== */
.modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9998;
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity .2s;
}

.modal-overlay.show {
    opacity: 1;
    pointer-events: all;
}

.modal-box {
    background: #0f172a;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 24px;
    width: 90%;
    max-width: 400px;
    color: white;
    font-family: inherit;
}

.btn-modal {
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 10px 20px;
    font-size: 14px;
    font-family: inherit;
    cursor: pointer;
    transition: background .2s;
}

.btn-modal:hover { background: #1d4ed8; }

.btn-modal-outline {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.12);
    color: #94a3b8;
}

.btn-modal-outline:hover {
    background: rgba(255,255,255,0.05);
    color: white;
}

/* ===== FADE IN (dùng cho fullscreen ảnh) ===== */
@keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
}
